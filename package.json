{
  "name": "@jiminp/stelaro-workspace",
  "version": "0.0.0",
  "description": "Opinionated Component System",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "clean": "pnpm -r --if-present clean",
    "build": "pnpm -r --if-present build",
    "build:watch": "pnpm --filter @jiminp/stelaro build:watch",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "build-docs": "typedoc",
    "build-docs-md": "typedoc --options typedoc.md.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jiminp/eslint-config": "^1.3.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1"
  },
  "dependencies": {
    "@jiminp/tooltool": "^0.3.3"
  }
}
