{
    "name": "Stelaro",
    "entryPoints": [
        "packages/stelaro",
        "packages/stelaro-discord",
        "packages/stelaro-fastify",
        "packages/stelaro-pino"
    ],
    "entryPointStrategy": "packages",
    "projectDocuments": ["guide/*.md"],
    "out": "docs",
    "exclude": ["**/*.spec.ts"],
    "useFirstParagraphOfCommentAsSummary": true,
    "packageOptions": {
        "groupReferencesByType": true,
        "categoryOrder": [
            "Application",
            "Lifecycle",
            "Component",
            "Configuration",
            "Logging",
            "Commands",
            "Events",
            "Interactions",
            "Gateway",
            "Mounts",
            "Routes",
            "Errors",
            "*"
        ]
    },
    "navigation": {
        "includeFolders": false,
        "includeCategories": true
    },
    "highlightLanguages": ["bash", "json", "ts", "toml"],
    "navigationLinks": {
        "GitHub": "https://github.com/123jimin/stelaro"
    }
}
